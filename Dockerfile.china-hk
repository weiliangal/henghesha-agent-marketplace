FROM node:22-bookworm-slim AS web-builder

WORKDIR /app/apps/marketplace-web
COPY apps/marketplace-web/package*.json ./
RUN npm install --include=optional --package-lock=false
COPY apps/marketplace-web ./
RUN npm run build

FROM node:22-bookworm-slim AS api-runtime

WORKDIR /app/apps/marketplace-api
COPY apps/marketplace-api/package*.json ./
RUN npm install --omit=dev

WORKDIR /app
ENV NODE_ENV=production
ENV PORT=4000

COPY apps/marketplace-api ./apps/marketplace-api
COPY --from=api-runtime /app/apps/marketplace-api/node_modules ./apps/marketplace-api/node_modules
COPY --from=web-builder /app/apps/marketplace-web/dist ./apps/marketplace-web/dist

EXPOSE 4000

CMD ["node", "apps/marketplace-api/src/server.js"]
